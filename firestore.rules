rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // كل مستخدم يقرأ ويكتب في مستنده فقط (بعد تسجيل الدخول).
    // لوحة الأدمن تقرأ الجميع عبر Admin SDK من السيرفر (تتجاوز هذه القواعد).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // أي مجموعة أخرى: ممنوعة بالكامل
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
